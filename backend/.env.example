# ─────────────────────────────────────────────────────────────────────────────
# LOST-iN-City — Backend Environment Variables
# Copy this file to .env and fill in real values.
# This file is safe to commit — it contains NO real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=your-mongodb-atlas-connection-string-here
MONGODB_DATABASE=lostcity

# JWT
JWT_SECRET=your-256-bit-secret-key-minimum-32-characters-long
JWT_EXPIRATION=86400000

# Clerk (from https://dashboard.clerk.com → API Keys)
CLERK_PUBLISHABLE_KEY=pk_test_...

# Kafka (local dev default — change for production)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=lost-city-group

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Server port
PORT=8080
